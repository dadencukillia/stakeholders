---
import Footer from "@/components/common/footer.astro";
import Header from "@/components/common/header.astro";
import { UserNavDynamic } from "@/components/features/profile/userNav";
import CTA from "@/components/features/promo/cta.astro";
import Hero from "@/components/features/promo/hero.astro";
import HowItWorks from "@/components/features/promo/howItWorks.astro";
import { Button } from "@/components/ui/button";
import Layout from "@/layouts/main.astro";

export const prerender = true;

interface NavLink {
  text: string,
  link: string
}

const navLinks: NavLink[] = [
  { text: "Get started", link: "#hero" },
  { text: "How it works", link: "#how-it-works" },
];
---

<Layout>
  <Header>
    <nav class="flex flex-1 flex-row gap-2 items-center text-center justify-center">
      { navLinks.map(nl => (
        <a key={ nl.text } href={ nl.link }>
          <Button variant="ghost" size="sm" className="hidden md:inline-flex">{ nl.text }</Button>
        </a>
      )) }
    </nav>
    <UserNavDynamic client:load />
  </Header>
  <main>
    <Hero />
    <HowItWorks />
    <CTA />
    <Footer />
  </main>
</Layout>
