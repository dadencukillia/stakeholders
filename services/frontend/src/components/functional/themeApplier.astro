---
/* 
 * Checks user's prefered theme or uses browser's theme
 * Adds "dark" class into <html> tag if the dark theme was chosen
 * Good for TailwindCSS websites
 * Put it in your <head> tag
 */

 import autoRunMinifiedScript from "@/lib/server/minifiedThemeScriptGenerator";
---

<script is:inline set:html={ autoRunMinifiedScript.code } type="module" />
