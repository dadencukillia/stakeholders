---
interface Section {
  title: string,
  description: string
}

const sections: Section[] = [
  { title: "Create a project", description: "Sign up and spin up a project. It gets its own Git repository on the Stakeholders server automatically." },
  { title: "Share the link", description: "Copy the read-only share link and send it to your client. No account required on their end." },
  { title: "They watch it happen", description: "Clients follow files, coding activity, AI status, and your presence live. You control status and access." },
];
---

<section
  id="how-it-works"
  class="border-y border-border/60 bg-card/30"
>
  <div class="container py-20">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-sm font-medium text-primary-foreground">How it works</p>
      <h2 class="mt-2 text-balance text-3xl font-semibold tracking-tight sm:text-4xl">
        From repo to client in three steps
      </h2>
    </div>
    <div class="mt-12 grid gap-6 md:grid-cols-3">
      { sections.map((s, index) => (
        <div 
          key={ s.title }
          class="relative rounded-xl border border-border bg-background p-6"
        >
          <span class="font-mono text-sm text-muted-foreground">{ (index + 1).toString().padStart(2, "0") }</span>
          <h3 class="mt-3 text-lg font-medium">{ s.title }</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
            { s.description }
          </p>
        </div>
      )) }
    </div>
  </div>
</section>
