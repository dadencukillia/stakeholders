---
import type { ProjectCardProps } from "@/lib/types/project";
import { Card, CardHeader, CardTitle, CardDescription, CardContent, CardFooter } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { Switch } from "@/components/ui/switch";
import { GitBranch, LockOpen, Lock, Copy, ArrowUpRight, SquareDashedText } from "@lucide/astro";
import StatusBadge from "./statusBadge.astro";

type Props = ProjectCardProps;

const props = Astro.props;
---

<Card className="group transition-colors hover:border-primary/40">
  <CardHeader>
    <div class="flex items-start justify-between gap-3">
      <CardTitle className="text-base">
        <a href={`/project/${ props.id }`} class="hover:underline">
          { props.title }
        </a>
      </CardTitle>
      <StatusBadge status={ props.status } />
    </div>
    <CardDescription className="line-clamp-2">{ props.description }</CardDescription>
  </CardHeader>
  <CardContent>
    <div class="flex items-center gap-4 text-xs text-muted-foreground">
      <span class="flex items-center gap-1.5 font-mono">
        <GitBranch class="size-3.5" />
        { props.branches } branches
      </span>
      <span>{ props.commits } commits</span>
      <span>{ props.workingHours } hrs on record</span>
    </div>
    { props.manualStatus && <div class="mt-4 flex items-center justify-between rounded-t-lg border border-border bg-background px-3 py-2">
      <div class="flex flex-row items-center gap-2 text-sm overflow-x-hidden" title={ props.manualStatus }>
        <SquareDashedText class="size-4 text-muted-foreground" />
        <span class="flex-1 wrap-break-word text-ellipsis line-clamp-2">{ props.manualStatus }</span>
      </div>
    </div> }
    <div class={ 
      ["flex items-center justify-between border-border bg-background px-3 py-2"].concat(props.manualStatus ? [
        "rounded-b-lg border-r border-l border-b"
      ] : [
        "mt-4 rounded-lg border"
      ]).join(" ")
    }>
      <div class="flex items-center gap-2 text-sm">
        { props.codeAccess ? (
          <LockOpen class="size-4 text-chart-2" />
        ) : (
          <Lock class="size-4 text-muted-foreground" />
        ) }
        <span class={ props.codeAccess ? "" : "text-muted-foreground" }>
          Code access
        </span>
      </div>
      <Switch
        checked={ props.codeAccess }
        aria-label="Toggle code access for stakeholders"
      />
    </div>
  </CardContent>
  <CardFooter className="gap-2 mt-auto">
    <Button variant="secondary" size="sm" className="flex-1">
      <Copy data-icon="inline-start" />
      Copy share link
    </Button>
    <a href={ `/project/${ props.id }` }>
      <Button
        size="sm"
        className="flex-1"
      >
        Open
        <ArrowUpRight data-icon="inline-end" />
      </Button>
    </a>
  </CardFooter>
</Card>
