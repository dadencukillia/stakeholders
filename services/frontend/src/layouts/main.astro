---
import "@/styles/global.css";
import ThemeApplier from "@/components/functional/themeApplier.astro";

interface Props {
  title: string
}

const {
  title = "My App"
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{ title }</title>

    <ThemeApplier />
  </head>
  <body>
    <slot />
  </body>
</html>
